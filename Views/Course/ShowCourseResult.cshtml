@model Course
@{
    ViewData["Title"] = "Course Results";
}

<h2>Course Results</h2>

<p><strong>Course:</strong> @Model.Name</p>

<table id="datatablesSimple" class="table table-bordered">
    <thead>
        <tr>
            <th>Trainee</th>
            <th>Degree</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Results.Any()) {
            foreach (var result in Model.Results) {
                <tr>
                    <td>
                        <a asp-controller="Trainee" asp-action="ShowTraineeResult" asp-route-id="@result.Trainee?.Id"
                           target="_blank" class="btn btn-outline-success btn-sm">
                            @result.Trainee?.Name
                        </a>
                    </td>
                    <td>@result.Degree</td>
                    <td>
                        <form asp-action="Delete" asp-controller="CrsResult" asp-route-id="@result.Id"
                              method="post" style="display:inline;"
                              onsubmit="return confirm('Are you sure you want to delete this result?');">
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                    
                </tr>
            }
        } else {
            <tr>
                <td colspan="2" class="text-muted text-center">No results yet</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" asp-controller="Course" class="btn btn-secondary">Back to Courses</a>
