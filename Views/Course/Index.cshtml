@model List<Course>
@{
    ViewData["Title"] = "Courses";
}

<h2>Courses</h2>
<table id="datatablesSimple" class="table">
    <tr>
        <th>Name</th>
        <th>Department</th>
        <th></th>
    </tr>
    @foreach (var i in Model) {
        <tr>
            <td>@i.Name</td>
            <td>@i.Department?.Name</td>
            <td>
                <a asp-action="Edit" asp-route-id="@i.Id" class="btn btn-info">Edit</a>
                <a asp-action="ShowCourseResult" asp-route-id="@i.Id" class="btn btn-info">Show Results</a>
                <form asp-action="Delete" asp-route-id="@i.Id" method="post" style="display:inline;"
                      onsubmit="return confirm('Are you sure you want to delete this course?');">
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
</table>
<a asp-action="Create" class="btn btn-primary">Add New Course</a>


