@model Instructor

@{
    ViewData["Title"] = "Add Instructor";
}

<h2>Add New Instructor</h2>

<form asp-action="Create" method="post">
    <div class="form-group mt-3">
        <lable asp-for="Name">Name</lable>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <lable asp-for="Salary">Salary</lable>
        <input asp-for="Salary" class="form-control" />
        <span asp-validation-for="Salary" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <lable asp-for="Imag">Image</lable>
        <input asp-for="Imag" class="form-control" />
        <span asp-validation-for="Imag" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <lable asp-for="Address">Address</lable>
        <input asp-for="Address" class="form-control" />
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <lable>Department</lable>
        <select asp-for="DeptId" asp-items="ViewBag.Departments" class="form-control">
            <option value="">-- Select Course --</option>
        </select>
        <span asp-validation-for="Department" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <lable>Course</lable>
        <select asp-for="CrsId" asp-items="ViewBag.Courses" class="form-control">
            <option value="">-- Select Course --</option>
        </select>
        <span asp-validation-for="Course" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
    
</form>