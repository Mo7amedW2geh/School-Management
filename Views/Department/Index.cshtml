@model List<Department>
@{
    ViewData["Title"] = "Departments";
}

<h2>Departments</h2>
<table id="datatablesSimple" class="table">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Manger</th>
        <th></th>
    </tr>
    @foreach (var i in Model) {
        <tr>
            <td>@i.Id</td>
            <td>@i.Name</td>
            <td>@i.Manger?.Name</td>
            <td>
                <a asp-action="Details" asp-route-id="@i.Id" class="btn btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@i.Id" class="btn btn-info">Edit</a>
                <form asp-action="Delete" asp-route-id="@i.Id" method="post" style="display:inline;"
                      onsubmit="return confirm('Are you sure you want to delete this department?');">
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
</table>
<a asp-action="Create" class="btn btn-primary">Add New Department</a>


