@model Trainee
@{
    ViewData["Title"] = "Trainee Result";
}

<h2>Trainee Results</h2>

<p><strong>Trainee:</strong> @Model.Name</p>

<a asp-controller="CrsResult" asp-action="Create" asp-route-traineeId="@Model.Id"
   class="btn btn-primary mb-3">Add Result</a>

<table id="datatablesSimple" class="table table-bordered">
    <thead>
        <tr>
            <th>Course</th>
            <th>Degree</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Results.Any()) {
            foreach (var result in Model.Results) {
                <tr>
                    <td>
                        <a asp-controller="Course" asp-action="ShowCourseResult" asp-route-id="@result.Course?.Id"
                           target="_blank" class="btn btn-outline-success btn-sm">
                            @result.Course?.Name
                        </a>
                    </td>
                    <td>@result.Degree</td>
                    <td>
                        <form asp-action="Delete" asp-controller="CrsResult" asp-route-id="@result.Id"
                              method="post" style="display:inline;"
                              onsubmit="return confirm('Are you sure you want to delete this result?');">
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        } else {
            <tr>
                <td colspan="2" class="text-muted text-center">No results yet</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Back to list</a>